# Application
SECRET_KEY=change-this-in-production
DATABASE_URL=sqlite:///internbuddy.db
PORT=5000

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://aswin-m-kumar.github.io

# Rate Limiting
RATELIMIT_STORAGE_URI=memory://

# Optional internship source domain allowlist for outbound scraping
# Leave blank to allow public internship links from any domain
ALLOWED_INTERNSHIP_DOMAINS=

# AI (NVIDIA NIM)
NVIDIA_API_KEY=your-api-key-here
OCR_SPACE_API_KEY=your-ocr-space-api-key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
SUMMARIZATION_MODEL=llama-3.1-8b-instant
SUMMARIZATION_MAX_TOKENS=400
ANALYSIS_MODEL=llama-3.3-70b-versatile
ANALYSIS_MAX_TOKENS=600

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Admin monitoring
ADMIN_KEY=your-admin-key-here

# Frontend build (GitHub Pages workflow)
VITE_API_URL=https://intern-buddy-cet.vercel.app
