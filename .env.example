# Application
SECRET_KEY=change-this-in-production
DATABASE_URL=sqlite:///internbuddy.db
PORT=5000

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://aswin-m-kumar.github.io/InternBuddy_CET

# Google OAuth (for Google sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Rate Limiting
RATELIMIT_STORAGE_URI=memory://

# AI (NVIDIA NIM)
NVIDIA_API_KEY=your-nvidia-api-key
OCR_SPACE_API_KEY=your-ocr-space-api-key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
SUMMARIZATION_MODEL=meta/llama-3.1-8b-instruct
ANALYSIS_MODEL=meta/llama-3.1-70b-instruct

# Admin monitoring
ADMIN_KEY=replace-with-a-strong-random-key

# Frontend build (GitHub Pages workflow)
VITE_API_URL=https://intern-buddy-cet.vercel.app
FRONTEND_URL=https://aswin-m-kumar.github.io/InternBuddy_CET
